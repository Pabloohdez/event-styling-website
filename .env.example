# Base de datos: para usar Supabase, pega la connection string (Session pooler).
# Deja sin definir para usar PostgreSQL del contenedor (desarrollo/local).
# DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require

# Seguridad: orígenes permitidos para CORS (solo en producción).
# En local no hace falta; por defecto se permiten localhost:4200 y localhost.
# En Google (Firebase Hosting) pon la URL de tu sitio, ej.:
# FRONTEND_ORIGIN=https://tu-proyecto.web.app,https://tu-proyecto.firebaseapp.com
# FRONTEND_ORIGIN=

# Notificación de contactos: email y móvil.
CONTACT_NOTIFY_EMAIL=pablohdez.545@gmail.com
## Nota: dejamos solo email (gratis). SMS/WhatsApp requieren proveedores de pago.

# SMTP para enviar email (Gmail: Contraseña de aplicación en cuenta Google).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=pablohdez.545@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx
